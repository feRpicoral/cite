# Cite — environment variables
#
# Every variable here is actively used by the code. Add new ones only when
# you ship the code that reads them.

# Public URL the app is served from. Used for metadataBase and Supabase
# email-confirmation callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Postgres. Use the pooled (port 6543) connection string for the
# app and the direct (port 5432) one for migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase Auth. Public keys are safe to embed in the client bundle; the
# service role key is server-only and bypasses RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI — embeddings (Phase 1: voyage-3-large, 2048 dims). Required for
# any document ingestion. Sign up at voyageai.com.
VOYAGE_API_KEY=

# LlamaCloud — PDF parsing (LlamaParse, Phase 1 decision). Required to
# ingest PDFs; DOCX/HTML/Markdown parse locally without an API key.
LLAMA_CLOUD_API_KEY=

# Anthropic — used for contextual-retrieval enrichment (Haiku) and for
# synthesis (Sonnet, Phase 5+). Optional for ingestion; quality drops if
# absent because chunks ship without contextual preambles.
ANTHROPIC_API_KEY=

# Inngest — required only in production deployments. In dev the SDK
# auto-connects to the local dev server (`inngest-cli dev`).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
