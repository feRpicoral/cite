// Cite — Prisma schema
//
// Multi-tenant B2B. Every tenant table carries `orgId`. Three layers of isolation:
//   1. Branded TypeScript IDs at call sites (src/lib/db/types.ts)
//   2. Prisma `$extends` middleware injects `orgId` (src/lib/db/with-org.ts)
//   3. Postgres RLS policies (prisma/sql/setup.sql)
//
// `User` mirrors Supabase `auth.users` via shared UUID; a trigger keeps it in sync.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, pgcrypto, uuidOssp(map: "uuid-ossp")]
}

// ─────────────────────────────────────────────
// Identity (mirror of Supabase auth.users)
// ─────────────────────────────────────────────

enum Locale {
  EN_US
  PT_BR

  @@map("locale")
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM

  @@map("theme_preference")
}

model User {
  id              String          @id @db.Uuid
  email           String          @unique
  name            String?
  avatarUrl       String?         @map("avatar_url")
  locale          Locale          @default(EN_US)
  themePreference ThemePreference @default(SYSTEM) @map("theme_preference")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  memberships    Membership[]
  invitesCreated Invite[]     @relation("InviteCreatedBy")

  @@map("users")
}

// ─────────────────────────────────────────────
// Organization + membership
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  invites     Invite[]

  @@map("organizations")
}

enum MembershipRole {
  ADMIN
  MEMBER

  @@map("membership_role")
}

model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("memberships")
}

model Invite {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  token           String         @unique
  email           String?
  role            MembershipRole @default(MEMBER)
  expiresAt       DateTime       @map("expires_at")
  acceptedAt      DateTime?      @map("accepted_at")
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])

  @@index([orgId])
  @@map("invites")
}

// ─────────────────────────────────────────────
// Document ingestion + retrieval
// ─────────────────────────────────────────────

enum DocumentFormat {
  PDF
  DOCX
  HTML
  MD

  @@map("document_format")
}

enum DocumentStatus {
  UPLOADING
  EXTRACTING
  CHUNKING
  EMBEDDING
  INDEXED
  FAILED

  @@map("document_status")
}

model Collection {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String
  description     String?
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  documents     Document[]
  conversations Conversation[]

  @@index([orgId])
  @@map("collections")
}

model Document {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  collectionId    String         @map("collection_id") @db.Uuid
  name            String
  format          DocumentFormat
  status          DocumentStatus @default(UPLOADING)
  storagePath     String         @map("storage_path")
  mimeType        String         @map("mime_type")
  sizeBytes       Int            @map("size_bytes")
  pageCount       Int?           @map("page_count")
  errorMessage    String?        @map("error_message")
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  indexedAt       DateTime?      @map("indexed_at")

  collection Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parts      DocumentPart[]
  chunks     DocumentChunk[]

  @@index([orgId, status])
  @@index([collectionId])
  @@map("documents")
}

model DocumentPart {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  // 0-based ordinal. For PDF, also the page number minus one. For
  // HTML-family, a section index in document order.
  index      Int
  // Sanitized HTML (for HTML-family) or raw text (for PDF).
  body       String
  // Per-format metadata. PDF: { pageNumber, width, height, rotation }.
  // HTML-family: { rootSelector, heading? }.
  metadata   Json
  createdAt  DateTime @default(now()) @map("created_at")

  document Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunks   DocumentChunk[]

  @@unique([documentId, index])
  @@index([orgId])
  @@map("document_parts")
}

model DocumentChunk {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  documentId         String   @map("document_id") @db.Uuid
  partId             String   @map("part_id") @db.Uuid
  // 0-based ordinal across the whole document.
  index              Int
  text               String
  // 1-2 sentence preamble produced by Anthropic Contextual Retrieval
  // (Phase 1 decision). Prepended to `text` before embedding; not used
  // when displaying the citation back to the user.
  contextualPreamble String?  @map("contextual_preamble")
  tokenCount         Int      @map("token_count")
  // Discriminated union matching DocumentLocation in src/lib/ingestion/location.ts.
  location           Json
  createdAt          DateTime @default(now()) @map("created_at")

  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  part      DocumentPart      @relation(fields: [partId], references: [id], onDelete: Cascade)
  embedding Embedding?
  citations MessageCitation[]

  @@unique([documentId, index])
  @@index([orgId])
  @@map("document_chunks")
}

model Embedding {
  id        String                      @id @default(uuid()) @db.Uuid
  orgId     String                      @map("org_id") @db.Uuid
  chunkId   String                      @unique @map("chunk_id") @db.Uuid
  // Voyage 3 large = 2048 dims (Phase 1 decision). Migrate if the provider changes.
  embedding Unsupported("vector(2048)")
  createdAt DateTime                    @default(now()) @map("created_at")

  chunk DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("embeddings")
}

// ─────────────────────────────────────────────
// Conversations + messages
// ─────────────────────────────────────────────

enum MessageRole {
  USER
  ASSISTANT

  @@map("message_role")
}

model Conversation {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  collectionId    String   @map("collection_id") @db.Uuid
  title           String
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([orgId, collectionId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  orgId          String      @map("org_id") @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String
  // For ASSISTANT messages: classify/sufficiency/sub-queries/rounds JSON.
  // Stored so the audit dashboard (Phase 8) can replay the agent's reasoning.
  agentState     Json?       @map("agent_state")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  citations    MessageCitation[]

  @@index([conversationId, createdAt])
  @@index([orgId])
  @@map("messages")
}

model MessageCitation {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  messageId    String   @map("message_id") @db.Uuid
  chunkId      String   @map("chunk_id") @db.Uuid
  // The [n] marker the assistant used in the rendered text.
  displayIndex Int      @map("display_index")
  // Snapshot of the chunk text at synthesis time so the popover survives
  // chunk deletion. The viewer still resolves to the live chunk's location.
  quote        String
  createdAt    DateTime @default(now()) @map("created_at")

  message Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk   DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([messageId, displayIndex])
  @@index([orgId])
  @@map("message_citations")
}

// ─────────────────────────────────────────────
// Comments (threaded; on messages or document regions)
// ─────────────────────────────────────────────

enum CommentTarget {
  MESSAGE
  DOCUMENT_REGION

  @@map("comment_target")
}

model Comment {
  id           String        @id @default(uuid()) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  targetType   CommentTarget @map("target_type")
  // For MESSAGE: the Message.id. For DOCUMENT_REGION: the Document.id.
  targetId     String        @map("target_id") @db.Uuid
  // Only set when targetType=DOCUMENT_REGION; serializes a DocumentLocation.
  location     Json?
  authorUserId String        @map("author_user_id") @db.Uuid
  body         String
  resolvedAt   DateTime?     @map("resolved_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  replies CommentReply[]

  @@index([orgId, targetType, targetId])
  @@map("comments")
}

model CommentReply {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  commentId    String   @map("comment_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
  @@index([orgId])
  @@map("comment_replies")
}

// ─────────────────────────────────────────────
// Citation-accuracy audit (Phase 8 — the differential metric)
// ─────────────────────────────────────────────

enum CitationVerdict {
  SUPPORTED
  PARTIAL
  UNSUPPORTED

  @@map("citation_verdict")
}

model CitationAudit {
  id           String          @id @default(uuid()) @db.Uuid
  orgId        String          @map("org_id") @db.Uuid
  messageId    String          @map("message_id") @db.Uuid
  displayIndex Int             @map("display_index")
  verdict      CitationVerdict
  reasoning    String
  confidence   Float
  resolves     Boolean?
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([messageId, displayIndex])
  @@index([orgId])
  @@map("citation_audits")
}

model MessageMetrics {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  messageId       String   @unique @map("message_id") @db.Uuid
  classifyMs      Int?     @map("classify_ms")
  retrievalMs     Int?     @map("retrieval_ms")
  sufficiencyMs   Int?     @map("sufficiency_ms")
  synthesisMs     Int?     @map("synthesis_ms")
  totalMs         Int      @map("total_ms")
  inputTokens     Int      @map("input_tokens")
  outputTokens    Int      @map("output_tokens")
  chunksRetrieved Int      @map("chunks_retrieved")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@map("message_metrics")
}
